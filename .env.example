# ════════════════════════════════════════════════════
#  AeroCommerce Microservices — Environment Variables
#  Copy file này thành .env và điền thông tin Supabase
# ════════════════════════════════════════════════════

# ── Supabase: UserService Database ───────────────────
# Lấy từ: Supabase Dashboard → Project → Settings → Database → Connection String (URI)
USER_SERVICE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Supabase: PostService Database ───────────────────
# (Có thể dùng chung 1 Supabase project, đổi database schema)
POST_SERVICE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── JWT Configuration ─────────────────────────────────
# Tạo secret mạnh: openssl rand -base64 64
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_ISSUER=AeroCommerce.UserService
JWT_AUDIENCE=AeroCommerce.Client
